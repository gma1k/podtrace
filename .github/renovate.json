{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":timezone(Europe/Amsterdam)",
    "schedule:earlyMondays"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "bump",
  "platformAutomerge": false,
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "schedule": []
  },
  "packageRules": [
    {
      "description": "Group all non-major Go module updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "go modules (non-major)"
    },
    {
      "description": "Pin Kubernetes ecosystem updates together",
      "matchPackagePatterns": [
        "^k8s\\.io/",
        "^sigs\\.k8s\\.io/"
      ],
      "groupName": "kubernetes ecosystem",
      "schedule": ["before 5am on monday"]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Dockerfile base image — security-sensitive, label clearly",
      "matchManagers": ["dockerfile"],
      "labels": ["dependencies", "container-image"]
    }
  ]
}
